{
  "name": "azat-io",
  "version": "1.0.0",
  "private": true,
  "description": "My personal website",
  "keywords": [
    "blog"
  ],
  "homepage": "https://azat.io",
  "repository": "azat-io/azat-io",
  "license": "CC-BY-NC-SA-4.0",
  "author": "Azat S. <to@azat.io>",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "start": "astro dev",
    "test": "pnpm run /^test:/",
    "test:astro": "astro check",
    "test:css": "stylelint \"**/*.{astro,svelte,css}\"",
    "test:format": "prettier --check \"**/*.{js,ts,astro,css,json,md,yml}\"",
    "test:js": "eslint --concurrency auto .",
    "test:markdown": "remark \"**/*.{md,mdx}\" --frail",
    "test:packages": "pnpm dedupe --check",
    "test:size": "pnpm run build && size-limit",
    "test:spelling": "cspell --config cspell.config.ts \"**/*\"",
    "test:svelte": "svelte-check",
    "test:types": "tsc --noEmit --pretty",
    "test:usage": "knip"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.1.1",
    "@kindspells/astro-shield": "^1.7.1",
    "@playform/compress": "^0.2.3",
    "@poppanator/sveltekit-svg": "^7.0.0",
    "@vercel/og": "^0.11.1",
    "astro": "^6.3.5",
    "browserslist": "^4.28.2",
    "hastscript": "^9.0.1",
    "iso-639-1": "^3.1.5",
    "json5": "^2.2.3",
    "katex": "^0.16.47",
    "lightningcss": "^1.32.0",
    "reading-time": "^1.5.0",
    "rehype-external-links": "^3.0.0",
    "remark-math": "^6.0.0",
    "remark-sectionize": "^2.1.0",
    "svelte": "^5.55.8",
    "typescript": "^6.0.3",
    "typograf": "^7.7.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@azat-io/eslint-config": "^2.80.0",
    "@azat-io/prettier-config": "^1.2.0",
    "@azat-io/stylelint-config": "^1.9.0",
    "@azat-io/typescript-config": "^1.1.1",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@cspell/dict-ru_ru": "^2.3.2",
    "@size-limit/file": "^12.1.0",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "cspell": "^10.0.0",
    "eslint": "^10.4.0",
    "knip": "^6.14.1",
    "nano-staged": "^1.0.2",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "remark-cli": "^12.0.1",
    "remark-lint-code-block-split-list": "^1.0.0",
    "remark-lint-fenced-code-flag": "^4.2.0",
    "remark-lint-heading-increment": "^4.0.1",
    "remark-lint-no-dead-urls": "^2.0.1",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.1.0",
    "stylelint": "^17.11.1",
    "svelte-check": "^4.4.8",
    "unified": "^11.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
